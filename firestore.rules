rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all rule for development (allows access if logged in)
    // You can refine this later to strictly restrict based on workspace member arrays
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /workspaces/{workspaceId} {
      // For now, allow any authenticated user to read/write workspaces (to allow invite acceptance)
      allow read, write: if request.auth != null;
    }

    match /invites/{tokenId} {
      allow read, write: if request.auth != null;
    }

    // Catch-all for anything else (if needed)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
